# ============================================================
# Lab-in-a-Box: Local AI — Environment Configuration
# Copy this file to .env and edit the values below.
#
#   cp .env.example .env
#
# ============================================================

# ----------------------------------------------------------
# DATA STORAGE
# Path on your ZimaOS host where Ollama and Open WebUI
# will store their data. Must be on writable storage
# (not the ZimaOS root filesystem, which is read-only).
#
# ZimaOS default writable location:
#   /media/zimadata
#
# Example — change "zimadata" to match your drive label:
# ----------------------------------------------------------
DATA_ROOT=/media/zimadata/ai

# ----------------------------------------------------------
# PORTS
# Change these if you have conflicts with other services.
# Default: Open WebUI on 3000, Ollama API on 11434
# ----------------------------------------------------------
WEBUI_PORT=3000
OLLAMA_PORT=11434

# ----------------------------------------------------------
# MEMORY LIMIT
# Sets a ceiling on RAM each container can use.
# Recommended minimums:
#   Low-RAM systems (8GB):  2g
#   Standard (16GB):        4g
#   High-RAM (32GB+):       8g
# ----------------------------------------------------------
MEMORY_LIMIT=4g
